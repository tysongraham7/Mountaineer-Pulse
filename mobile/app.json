{
  "expo": {
    "name": "Mountaineer Pulse",
    "slug": "mountaineer-pulse",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mountaineerpulse",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060B16",
    "ios": {
      "bundleIdentifier": "com.tysongraham.mountaineerpulse",
      "supportsTablet": false,
      "userInterfaceStyle": "dark",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tysongraham.mountaineerpulse",
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "backgroundColor": "#002855",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#060B16",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#EAA000"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "tyson-graham",
          "project": "mountaineer-pulse"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98cf430a-90b9-4d07-b268-3d2404a71d46"
      }
    },
    "owner": "tysongraham7",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98cf430a-90b9-4d07-b268-3d2404a71d46"
    }
  }
}
